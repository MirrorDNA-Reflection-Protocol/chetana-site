{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chetana Trust Bundle Schema",
  "type": "object",
  "required": [
    "send_guard"
  ],
  "properties": {
    "send_guard": {
      "type": "object",
      "required": [
        "assessment_id",
        "assessed_at_utc",
        "decision",
        "risk_score",
        "manipulation_signals",
        "decision_reasons",
        "interventions",
        "recommended_actions"
      ],
      "properties": {
        "assessment_id": { "type": "string" },
        "assessed_at_utc": { "type": "string", "format": "date-time" },
        "decision": {
          "type": "string",
          "enum": ["ALLOW", "CONFIRM", "COOLDOWN", "HARD_STOP"]
        },
        "risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "manipulation_signals": { "type": "array", "items": { "type": "string" } },
        "decision_reasons": { "type": "array", "items": { "type": "string" } },
        "interventions": { "type": "array", "items": { "type": "string" } },
        "recommended_actions": { "type": "array", "items": { "type": "string" } },
        "recovery_packet": {
          "$ref": "./chetana_recovery_packet_schema.json"
        }
      },
      "additionalProperties": false
    },
    "merchant_release": {
      "type": ["object", "null"],
      "properties": {
        "session_id": { "type": "string" },
        "assessed_at_utc": { "type": "string", "format": "date-time" },
        "merchant_label": { "type": "string" },
        "amount_inr": { "type": "integer" },
        "decision": {
          "type": "string",
          "enum": ["VERIFIED", "PENDING", "DO_NOT_RELEASE", "EXPIRED"]
        },
        "proof_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "hold_until_utc": { "type": "string", "format": "date-time" },
        "decision_reasons": { "type": "array", "items": { "type": "string" } },
        "recommended_actions": { "type": "array", "items": { "type": "string" } },
        "recovery_packet": {
          "$ref": "./chetana_recovery_packet_schema.json"
        }
      },
      "additionalProperties": false
    },
    "recovery_packet": {
      "oneOf": [
        { "$ref": "./chetana_recovery_packet_schema.json" },
        { "type": "null" }
      ]
    }
  },
  "additionalProperties": false
}
