{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chetana Recovery Packet Schema",
  "type": "object",
  "required": [
    "packet_id",
    "generated_at_utc",
    "incident_type",
    "summary",
    "immediate_actions",
    "official_rails",
    "escalation_order",
    "handoff_script",
    "case_packet"
  ],
  "properties": {
    "packet_id": { "type": "string" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "incident_type": {
      "type": "string",
      "enum": [
        "AUTHORIZED_PUSH_PAYMENT_FRAUD",
        "WRONG_RECIPIENT_TRANSFER",
        "MERCHANT_PAYMENT_DISPUTE",
        "IMPERSONATION_ATTEMPT_BLOCKED",
        "PAYMENT_DISPUTE"
      ]
    },
    "summary": { "type": "string" },
    "immediate_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "official_rails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rail_id",
          "name",
          "channel",
          "official_url",
          "verified_on",
          "use_when"
        ],
        "properties": {
          "rail_id": {
            "type": "string",
            "enum": [
              "BANK_APP_SUPPORT",
              "CYBER_HELPLINE_1930",
              "NCRP_PORTAL",
              "RBI_CMS"
            ]
          },
          "name": { "type": "string" },
          "channel": { "type": "string" },
          "contact": { "type": "string" },
          "official_url": { "type": "string" },
          "verified_on": { "type": "string" },
          "use_when": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "escalation_order": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "handoff_script": { "type": "string" },
    "case_packet": {
      "type": "object",
      "required": [
        "phone_numbers",
        "urls",
        "upi_ids",
        "merchant_names",
        "summary"
      ],
      "properties": {
        "amount_inr": { "type": "integer" },
        "transaction_reference": { "type": "string" },
        "phone_numbers": { "type": "array", "items": { "type": "string" } },
        "urls": { "type": "array", "items": { "type": "string" } },
        "upi_ids": { "type": "array", "items": { "type": "string" } },
        "merchant_names": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
