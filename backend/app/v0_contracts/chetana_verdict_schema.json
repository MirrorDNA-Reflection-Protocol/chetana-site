{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chetana Verdict Schema",
  "type": "object",
  "required": [
    "scan_id",
    "timestamp_utc",
    "input_type",
    "verdict",
    "risk_level",
    "scam_type",
    "confidence_band",
    "evidence_state",
    "incident_state",
    "reasons",
    "guidance",
    "recommended_actions"
  ],
  "properties": {
    "scan_id": {
      "type": "string",
      "description": "Unique scan identifier"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "input_type": {
      "type": "string",
      "enum": [
        "screenshot",
        "text",
        "qr_image",
        "payment_screenshot",
        "mixed"
      ]
    },
    "language_hint": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "high_risk",
        "caution",
        "needs_review",
        "low_signal"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "scam_type": {
      "type": "string",
      "enum": [
        "investment_scam",
        "fake_kyc",
        "upi_qr_scam",
        "fake_payment_proof",
        "parcel_customs_scam",
        "job_scam",
        "remote_support_scam",
        "impersonation_pressure_scam",
        "unknown_suspicious_pattern"
      ]
    },
    "confidence_band": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "evidence_state": {
      "type": "string",
      "enum": ["complete", "partial", "weak", "conflicting"]
    },
    "incident_state": {
      "type": "string",
      "enum": [
        "suspected",
        "active_coercion",
        "payment_requested",
        "payment_attempted",
        "device_access_requested"
      ]
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "code",
          "label",
          "explanation"
        ],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "urgency_pressure",
              "asks_for_money",
              "suspicious_return_claim",
              "impersonates_authority",
              "identity_mismatch",
              "suspicious_url",
              "qr_payload_mismatch",
              "payment_screenshot_anomaly",
              "move_off_platform",
              "threat_language",
              "language_inconsistency",
              "hidden_or_shortened_link",
              "unverifiable_contact",
              "remote_access_request"
            ]
          },
          "label": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "entities": {
      "type": "object",
      "properties": {
        "phone_numbers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "upi_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "amounts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "merchant_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "person_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "summary_plain_language": {
      "type": "string"
    },
    "safe_next_step": {
      "type": "string"
    },
    "guidance": {
      "type": "object",
      "required": [
        "lead",
        "why_it_was_flagged",
        "do_now",
        "do_not_do",
        "if_already_acted",
        "verification_route",
        "false_positive_recovery",
        "calm_script",
        "source"
      ],
      "properties": {
        "lead": { "type": "string" },
        "why_it_was_flagged": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string" }
        },
        "do_now": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string" }
        },
        "do_not_do": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": { "type": "string" }
        },
        "if_already_acted": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": { "type": "string" }
        },
        "verification_route": { "type": "string" },
        "false_positive_recovery": { "type": "string" },
        "calm_script": { "type": "string" },
        "source": {
          "type": "string",
          "enum": ["deterministic", "ollama"]
        }
      },
      "additionalProperties": false
    },
    "recommended_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "do_not_pay",
          "verify_with_official_source",
          "share_with_family",
          "save_evidence",
          "report_and_block",
          "scan_again_with_more_context",
          "treat_as_unclear"
        ]
      }
    },
    "share_shield_eligible": {
      "type": "boolean"
    },
    "evidence_pack_eligible": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
