<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Use only if justified by Play policy and user-facing core security function. -->
    <!-- <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" /> -->

    <application>

        <service
            android:name=".NotificationWatcherService"
            android:label="Chetana Risk Watch"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".InstallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- Merge this intent filter into the app's existing MainActivity. -->
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="application/vnd.android.package-archive" />
            </intent-filter>
        </activity>

    </application>
</manifest>
